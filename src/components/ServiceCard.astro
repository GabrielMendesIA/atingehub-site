---
interface Props {
  title: string;
  description: string;
  products: string[];
  accent?: string;
}

const { title, description, products, accent = 'var(--accent)' } = Astro.props;
---

<article class="service-card" style={`--card-accent: ${accent}`}>
  <div class="service-icon">
    <span class="dot"></span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <ul class="prod-list">
    {products.map((p) => <li>{p}</li>)}
  </ul>
</article>

<style>
  .service-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: border-color 0.2s, transform 0.2s;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    border-color: var(--card-accent);
    transform: translateY(-3px);
  }

  .service-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--bg-input);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--card-accent);
  }

  h3 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--text);
  }
  p {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-muted);
    margin-bottom: 18px;
    flex: 1;
  }

  .prod-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }
  .prod-list li {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 10px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    color: var(--text-muted);
    letter-spacing: 0.3px;
  }
</style>
