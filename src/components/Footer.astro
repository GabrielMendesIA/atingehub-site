---
import LogoMark from './LogoMark.astro';
import { site } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-page footer-grid">
    <div class="foot-brand">
      <div class="foot-logo">
        <LogoMark size={28} />
        <span class="foot-name">Atinge<span class="foot-hub">HUB</span></span>
      </div>
      <p class="foot-tagline">{site.tagline}</p>
      <p class="foot-email">
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
      </p>
    </div>

    <div class="foot-col">
      <h4>Navegar</h4>
      <ul>
        <li><a href="/#servicos">Serviços</a></li>
        <li><a href="/#processo">Processo</a></li>
        <li><a href="/workshop">Workshop</a></li>
        <li><a href="/#contato">Contato</a></li>
      </ul>
    </div>

    <div class="foot-col">
      <h4>Conectar</h4>
      <ul>
        <li><a href={site.social.instagram} target="_blank" rel="noopener">Instagram</a></li>
        <li><a href={site.social.github} target="_blank" rel="noopener">GitHub</a></li>
      </ul>
    </div>
  </div>

  <div class="container-page foot-base">
    <p>© {year} {site.name} — {site.contact.address}</p>
    <p class="foot-region">Atende {site.contact.region.slice(0, 3).join(' · ')}…</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-soft);
    padding: 64px 0 32px;
    margin-top: 96px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  @media (min-width: 700px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 64px;
    }
  }

  .foot-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .foot-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 18px;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .foot-hub { color: var(--accent); font-weight: 900; }

  .foot-tagline {
    color: var(--text-muted);
    font-size: 14px;
    max-width: 320px;
  }
  .foot-email {
    margin-top: 14px;
    font-size: 14px;
  }

  .foot-col h4 {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 16px;
  }
  .foot-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .foot-col a {
    color: var(--text-muted);
    font-size: 14px;
  }
  .foot-col a:hover { color: var(--text); }

  .foot-base {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    font-size: 12px;
    color: var(--text-dim);
  }
  .foot-base p { color: var(--text-dim); font-size: 12px; }
</style>
