---
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl';
  hubColor?: string;
}
const { size = 'md', hubColor } = Astro.props;

const sizeClass = {
  sm: 'wm-sm',
  md: 'wm-md',
  lg: 'wm-lg',
  xl: 'wm-xl',
}[size];
---

<span class:list={['wordmark', sizeClass]}>
  Atinge<span class="hub" style={hubColor ? `color: ${hubColor}` : ''}>HUB</span>
</span>

<style>
  .wm-sm { font-size: 16px; }
  .wm-md { font-size: 22px; }
  .wm-lg { font-size: 36px; }
  .wm-xl { font-size: clamp(42px, 5.5vw, 64px); }
</style>
