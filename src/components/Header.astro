---
import { navigation, whatsappLink, site } from '../config/site';
---

<!-- Spacer pra reservar o espaço da logo grande -->
<div class="header-spacer" aria-hidden="true"></div>

<!-- Fade escuro atrás do header — aparece ao rolar -->
<div class="header-fade" aria-hidden="true"></div>

<!-- Wordmark fixo no canto esquerdo -->
<a href="/" class="brand-wordmark" aria-label={`${site.name} — Início`}>
  Atinge<span class="hub">HUB</span>
</a>

<!-- Logo flutuante centralizada — encolhe ao rolar -->
<a href="/" class="logo-floating" aria-label={`${site.name} — Início`}>
  <svg viewBox="0 0 100 80" aria-hidden="true">
    <path d="M16 64L28 42L40 64Z" fill="#4A4A4A" />
    <path d="M60 64L74 38L88 64Z" fill="#8A8A8A" />
    <path d="M24 64L50 16L76 64Z" fill="#F5F3EE" />
    <path d="M50 16L50 6" stroke="#D97757" stroke-width="2.5" stroke-linecap="round" />
    <path d="M50 7L60 9L50 13Z" fill="#D97757" />
  </svg>
</a>

<!-- Hamburger flutuante à direita (só ícone) -->
<button
  type="button"
  class="menu-toggle"
  aria-label="Abrir menu"
  aria-expanded="false"
  data-menu-toggle
>
  <span class="bars" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </span>
</button>

<!-- Overlay com clip-path circular -->
<div class="menu-overlay" data-menu-overlay hidden>
  <button
    type="button"
    class="menu-close"
    aria-label="Fechar menu"
    data-menu-close
  >×</button>

  <nav class="menu-nav" aria-label="Principal">
    <ul>
      {navigation.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>

    <div class="menu-footer">
      <span class="menu-eyebrow">Falar comigo</span>
      <div class="menu-ctas">
        <a href={whatsappLink()} target="_blank" rel="noopener" class="btn btn-whatsapp menu-cta">
          WhatsApp direto
        </a>
        <a href="/#contato" class="btn btn-ghost menu-cta">
          Agendar conversa
        </a>
      </div>
    </div>
  </nav>
</div>

<style>
  /* ─── Spacer (reserva espaço da logo grande) ──────────────── */
  .header-spacer {
    height: 200px;
    width: 100%;
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .header-spacer { height: 150px; }
  }

  /* ─── Fade escuro atrás do header (aparece ao rolar) ──────── */
  .header-fade {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    z-index: 55;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 11, 0.9) 0%,
      rgba(10, 10, 11, 0.7) 60%,
      rgba(10, 10, 11, 0) 100%
    );
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    transition: opacity 400ms ease-out;
  }
  @media (max-width: 768px) {
    .header-fade { height: 64px; }
  }
  :global(body[data-scrolled='true']) .header-fade { opacity: 1; }
  :global(body[data-menu='open']) .header-fade { opacity: 0; }

  /* ─── Wordmark fixo à esquerda ────────────────────────────── */
  .brand-wordmark {
    position: fixed;
    top: 18px;
    left: 24px;
    z-index: 60;
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.035em;
    font-size: 20px;
    line-height: 1;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 200ms;
  }
  .brand-wordmark:hover { color: var(--text); opacity: 0.85; }
  .brand-wordmark .hub {
    font-weight: 900;
    color: var(--accent);
  }
  @media (max-width: 768px) {
    .brand-wordmark { top: 16px; left: 18px; font-size: 17px; }
  }

  /* ─── Logo flutuante centralizada (encolhe no scroll) ─────── */
  .logo-floating {
    position: fixed;
    top: 40px;
    left: 50%;
    z-index: 60;
    display: block;
    width: 140px;
    height: 112px;
    transform: translateX(-50%);
    filter: drop-shadow(0 0 24px rgba(217, 119, 87, 0.4));
    transition:
      top 700ms cubic-bezier(0.22, 1, 0.36, 1),
      width 700ms cubic-bezier(0.22, 1, 0.36, 1),
      height 700ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .logo-floating svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  :global(body[data-scrolled='true']) .logo-floating {
    top: 8px;
    width: 50px;
    height: 40px;
    filter: drop-shadow(0 0 10px rgba(217, 119, 87, 0.5));
  }
  @media (max-width: 768px) {
    .logo-floating { top: 36px; width: 108px; height: 86px; }
    :global(body[data-scrolled='true']) .logo-floating {
      top: 6px; width: 44px; height: 35px;
    }
  }

  /* Esconde brand e logo quando menu aberto */
  :global(body[data-menu='open']) .brand-wordmark,
  :global(body[data-menu='open']) .logo-floating {
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms;
  }

  /* ─── Hamburger (só ícone, sem palavra) ───────────────────── */
  .menu-toggle {
    position: fixed;
    top: 16px;
    right: 20px;
    z-index: 70;
    width: 48px;
    height: 48px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-full);
    background: rgba(15, 15, 18, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    color: var(--text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    transition:
      border-color 200ms,
      transform 200ms,
      background 200ms,
      box-shadow 200ms;
  }
  .menu-toggle:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(217, 119, 87, 0.25);
  }
  .menu-toggle:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  @media (max-width: 768px) {
    .menu-toggle { top: 12px; right: 14px; width: 44px; height: 44px; }
  }

  .bars {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
  }
  .bars span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 300ms, opacity 300ms;
  }

  :global(body[data-menu='open']) .menu-toggle {
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms;
  }

  /* ─── Overlay com clip-path circular ──────────────────────── */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: var(--bg);
    overflow-y: auto;
    clip-path: circle(0% at calc(100% - 40px) 40px);
    transition: clip-path 600ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .menu-overlay[hidden] { display: none; }
  .menu-overlay.is-visible {
    clip-path: circle(150% at calc(100% - 40px) 40px);
  }
  .menu-overlay::after {
    content: '';
    position: fixed;
    top: -30%;
    right: -10%;
    width: 80vw;
    height: 80vh;
    background: radial-gradient(ellipse, var(--accent-glow), transparent 60%);
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  .menu-close {
    position: absolute;
    top: 16px;
    right: 20px;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text);
    font-size: 26px;
    line-height: 1;
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: border-color 200ms, transform 300ms;
  }
  .menu-close:hover {
    border-color: var(--text);
    transform: rotate(90deg);
  }
  @media (max-width: 768px) {
    .menu-close { top: 12px; right: 14px; width: 44px; height: 44px; font-size: 24px; }
  }

  .menu-nav {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 32px 48px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (max-width: 768px) {
    .menu-nav { padding: 96px 24px 40px; }
  }

  .menu-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .menu-nav ul a {
    display: block;
    padding: 8px 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-style: italic;
    font-size: clamp(38px, 6vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
    transition: color 200ms, transform 200ms;
  }
  .menu-nav ul a:hover {
    color: var(--accent);
    transform: translateX(4px);
  }

  .menu-footer {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .menu-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .menu-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .menu-cta { padding: 14px 22px; }
</style>

<script>
  function updateScrollState() {
    if (window.scrollY > 40) {
      document.body.dataset.scrolled = 'true';
    } else {
      delete document.body.dataset.scrolled;
    }
  }
  window.addEventListener('scroll', updateScrollState, { passive: true });
  updateScrollState();

  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const close = document.querySelector<HTMLButtonElement>('[data-menu-close]');
  const overlay = document.querySelector<HTMLElement>('[data-menu-overlay]');

  function openMenu() {
    if (!overlay) return;
    document.body.dataset.menu = 'open';
    document.body.style.overflow = 'hidden';
    overlay.removeAttribute('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    void overlay.offsetWidth;
    requestAnimationFrame(() => {
      requestAnimationFrame(() => overlay.classList.add('is-visible'));
    });
  }

  function closeMenu() {
    if (!overlay) return;
    delete document.body.dataset.menu;
    document.body.style.overflow = '';
    overlay.classList.remove('is-visible');
    toggle?.setAttribute('aria-expanded', 'false');
    setTimeout(() => overlay.setAttribute('hidden', ''), 600);
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.body.dataset.menu === 'open') closeMenu();
  });

  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
