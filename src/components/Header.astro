---
import { navigation, whatsappLink, site } from '../config/site';
---

<!-- Spacer reserva o espaço da logo grande inicial — evita CLS quando encolhe -->
<div class="header-spacer" aria-hidden="true"></div>

<!-- Fade escuro atrás do header — aparece ao rolar -->
<div class="header-fade" aria-hidden="true"></div>

<!-- Wordmark fixo no canto esquerdo, sempre igual -->
<a href="/" class="brand-wordmark-fixed" aria-label={`${site.name} — Início`}>
  Atinge<span class="hub">HUB</span>
</a>

<!-- Logo flutuante centralizada — só encolhe ao rolar, não migra -->
<a href="/" class="logo-floating" aria-label={`${site.name} — Início`} data-brand>
  <svg viewBox="0 0 100 80" aria-hidden="true">
    <path d="M16 64L28 42L40 64Z" fill="#4A4A4A" />
    <path d="M60 64L74 38L88 64Z" fill="#8A8A8A" />
    <path d="M24 64L50 16L76 64Z" fill="#F5F3EE" />
    <path d="M50 16L50 6" stroke="#D97757" stroke-width="2.5" stroke-linecap="round" />
    <path d="M50 7L60 9L50 13Z" fill="#D97757" />
  </svg>
</a>

<!-- Hamburger flutuante à direita -->
<button
  type="button"
  class="menu-floating"
  aria-label="Abrir menu"
  data-menu-toggle
>
  <span class="menu-icon">
    <span></span>
    <span></span>
    <span></span>
  </span>
  <span class="menu-label">menu</span>
</button>

<!-- Menu overlay (clip-path expanding from hamburger) -->
<div class="menu-overlay" data-menu-overlay hidden>
  <button
    type="button"
    class="menu-close"
    aria-label="Fechar menu"
    data-menu-close
  >×</button>

  <nav class="menu-nav" aria-label="Principal">
    <ul>
      {navigation.map((item) => (
        <li>
          <a href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>

    <div class="menu-footer">
      <p class="eyebrow"><span class="accent">●</span> Falar comigo</p>
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener"
        class="btn btn-primary menu-cta"
      >
        $ iniciar conversa →
      </a>
    </div>
  </nav>
</div>

<style>
  /* ─── Spacer (reserva espaço da logo grande) ───────────────── */
  .header-spacer {
    height: 220px;
    width: 100%;
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .header-spacer {
      height: 180px;
    }
  }

  /* ─── Fade escuro atrás do header (aparece ao rolar) ───────── */
  .header-fade {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 140px;
    z-index: 55;
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 5, 0.85) 0%,
      rgba(5, 5, 5, 0.6) 50%,
      rgba(5, 5, 5, 0) 100%
    );
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 500ms ease-out;
  }
  :global(body[data-scrolled='true']) .header-fade {
    opacity: 1;
  }
  :global(body[data-menu='open']) .header-fade {
    opacity: 0;
  }

  /* ─── Wordmark fixo no canto esquerdo ──────────────────────── */
  .brand-wordmark-fixed {
    position: fixed;
    top: 18px;
    left: 24px;
    z-index: 60;
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    font-size: 22px;
    line-height: 1;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
  }
  .brand-wordmark-fixed:hover {
    color: var(--text);
    opacity: 0.85;
  }
  .brand-wordmark-fixed .hub {
    font-weight: 900;
    color: var(--claude);
  }

  /* ─── Logo flutuante centralizada — apenas encolhe ─────────── */
  .logo-floating {
    position: fixed;
    top: 56px;
    left: 50%;
    z-index: 60;
    display: block;
    width: 160px;
    height: 128px;
    transform: translateX(-50%);
    filter: drop-shadow(0 0 28px rgba(217, 119, 87, 0.4));
    transition:
      top 800ms cubic-bezier(0.22, 1, 0.36, 1),
      width 800ms cubic-bezier(0.22, 1, 0.36, 1),
      height 800ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 800ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .logo-floating svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Estado compacto (scroll > 40px) — logo encolhe e sobe, fica centralizada */
  :global(body[data-scrolled='true']) .logo-floating {
    top: 8px;
    width: 56px;
    height: 45px;
    filter: drop-shadow(0 0 12px rgba(217, 119, 87, 0.5));
  }

  /* Mobile ajustes ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .brand-wordmark-fixed {
      top: 16px;
      left: 18px;
      font-size: 18px;
    }
    .logo-floating {
      top: 48px;
      width: 120px;
      height: 96px;
    }
    :global(body[data-scrolled='true']) .logo-floating {
      top: 6px;
      width: 48px;
      height: 38px;
    }
  }

  /* Estado menu aberto — escondem temporariamente atrás do overlay */
  :global(body[data-menu='open']) .brand-wordmark-fixed,
  :global(body[data-menu='open']) .logo-floating {
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms;
  }

  /* ─── Hamburger flutuante ──────────────────────────────────── */
  .menu-floating {
    position: fixed;
    top: 16px;
    right: 20px;
    z-index: 70;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--bg) 75%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    color: var(--text);
    cursor: pointer;
    transition:
      padding 300ms ease-out,
      background 200ms,
      border-color 200ms,
      transform 200ms;
  }
  .menu-floating:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }

  .menu-icon {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
  }
  .menu-icon span {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--text);
    transition: width 300ms;
  }

  .menu-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: lowercase;
    font-weight: 500;
  }

  /* Hamburger no estado compacto cresce um pouco */
  :global(body[data-scrolled='true']) .menu-floating {
    padding: 12px 18px;
  }
  :global(body[data-scrolled='true']) .menu-icon span {
    width: 18px;
  }

  /* Menu aberto = esconder hamburger */
  :global(body[data-menu='open']) .menu-floating {
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms;
  }

  @media (max-width: 768px) {
    .menu-floating {
      top: 12px;
      right: 14px;
      padding: 8px 14px;
    }
  }

  /* ─── Menu overlay (clip-path circular) ────────────────────── */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: var(--bg);
    overflow-y: auto;
    clip-path: circle(0% at calc(100% - 48px) 36px);
    transition: clip-path 600ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .menu-overlay[hidden] {
    display: none;
  }
  .menu-overlay.is-visible {
    clip-path: circle(150% at calc(100% - 48px) 36px);
  }
  .menu-overlay::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }
  .menu-overlay::after {
    content: '';
    position: fixed;
    top: -40%;
    right: -10%;
    width: 90vw;
    height: 90vh;
    background: radial-gradient(ellipse, var(--claude-glow), transparent 60%);
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }

  .menu-close {
    position: absolute;
    top: 18px;
    right: 22px;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text);
    font-size: 28px;
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 200ms, transform 200ms;
  }
  .menu-close:hover {
    border-color: var(--text);
    transform: rotate(90deg);
  }

  .menu-nav {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 32px 48px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .menu-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .menu-nav ul a {
    display: block;
    padding: 6px 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-style: italic;
    font-size: clamp(38px, 6vw, 64px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--text);
    transition: color 200ms;
  }
  .menu-nav ul a:hover {
    color: var(--claude);
  }

  .menu-footer {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .menu-cta {
    margin-top: 14px;
  }
</style>

<script>
  // Scroll state (compacto / expandido)
  function updateScrollState() {
    if (window.scrollY > 40) {
      document.body.dataset.scrolled = 'true';
    } else {
      delete document.body.dataset.scrolled;
    }
  }
  window.addEventListener('scroll', updateScrollState, { passive: true });
  updateScrollState();

  // Menu open/close com clip-path circular
  const toggle = document.querySelector('[data-menu-toggle]');
  const close = document.querySelector('[data-menu-close]');
  const overlay = document.querySelector('[data-menu-overlay]');

  function openMenu() {
    if (!overlay) return;
    document.body.dataset.menu = 'open';
    document.body.style.overflow = 'hidden';
    overlay.removeAttribute('hidden');
    // Force reflow pra clip-path animar
    void (overlay as HTMLElement).offsetWidth;
    requestAnimationFrame(() => {
      requestAnimationFrame(() => overlay.classList.add('is-visible'));
    });
  }

  function closeMenu() {
    if (!overlay) return;
    delete document.body.dataset.menu;
    document.body.style.overflow = '';
    overlay.classList.remove('is-visible');
    setTimeout(() => overlay.setAttribute('hidden', ''), 600);
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);

  // Fechar com ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.body.dataset.menu === 'open') {
      closeMenu();
    }
  });

  // Fechar ao clicar em link
  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
