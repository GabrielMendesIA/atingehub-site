---
import { site, navigation, whatsappLink } from '../config/site';
---

<header class="site-header">
  <div class="container-page flex items-center justify-between py-5">
    <a href="/" class="brand" aria-label={site.name}>
      <span class="brand-mark">A</span>
      <span class="brand-name">{site.name}</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm" aria-label="Principal">
      {navigation.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={whatsappLink()}
      target="_blank"
      rel="noopener"
      class="btn btn-whatsapp hidden md:inline-flex text-sm"
    >
      WhatsApp
    </a>

    <button
      type="button"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Abrir menu"
      data-menu-toggle
    >
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-6 h-0.5 bg-current"></span>
      <span class="block w-6 h-0.5 bg-current"></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu hidden>
    <div class="container-page py-8 flex flex-col gap-4">
      {navigation.map((item) => (
        <a href={item.href} class="mobile-nav-link">
          {item.label}
        </a>
      ))}
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener"
        class="btn btn-whatsapp mt-4"
      >
        Falar no WhatsApp
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-paper) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-line);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .brand:hover { color: var(--color-ink); }

  .brand-mark {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    background: var(--color-ink);
    color: var(--color-paper);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
    font-style: italic;
  }

  .nav-link {
    color: var(--color-ink-soft);
    font-weight: 500;
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--color-ink); }

  .mobile-menu {
    border-top: 1px solid var(--color-line);
    background: var(--color-paper);
  }
  .mobile-menu[hidden] { display: none; }

  .mobile-nav-link {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-ink);
    padding: 0.5rem 0;
  }
</style>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  toggle?.addEventListener('click', () => {
    if (!menu) return;
    const isHidden = menu.hasAttribute('hidden');
    if (isHidden) {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-label', 'Fechar menu');
    } else {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-label', 'Abrir menu');
    }
  });
</script>
