---
import { navigation, whatsappLink } from '../config/site';
import LogoMark from './LogoMark.astro';
import Wordmark from './Wordmark.astro';
---

<header class="site-header">
  <div class="container-page header-row">
    <a href="/" class="brand" aria-label="AtingeHUB — Home">
      <LogoMark size={32} />
      <Wordmark size="sm" />
    </a>

    <nav class="nav-desktop" aria-label="Principal">
      {navigation.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={whatsappLink()}
      target="_blank"
      rel="noopener"
      class="btn btn-primary nav-cta"
    >
      $ iniciar conversa
    </a>

    <button
      type="button"
      class="menu-toggle"
      aria-label="Abrir menu"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu hidden>
    <div class="container-page mobile-menu-inner">
      {navigation.map((item) => (
        <a href={item.href} class="mobile-nav-link">
          {item.label}
        </a>
      ))}
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener"
        class="btn btn-primary mt-4"
      >
        $ iniciar conversa →
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 32px;
    gap: 16px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--text);
    transition: opacity 0.2s;
  }
  .brand:hover {
    opacity: 0.85;
    color: var(--text);
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 32px;
    margin-left: auto;
    margin-right: 24px;
  }
  @media (min-width: 920px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.5px;
    text-transform: lowercase;
    transition: color 0.15s;
  }
  .nav-link:hover {
    color: var(--text);
  }

  .nav-cta {
    display: none;
  }
  @media (min-width: 920px) {
    .nav-cta {
      display: inline-flex;
    }
  }

  .menu-toggle {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    padding: 10px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
  }
  .menu-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text);
  }
  @media (min-width: 920px) {
    .menu-toggle {
      display: none;
    }
  }

  .mobile-menu {
    border-top: 1px solid var(--border);
    background: var(--bg);
  }
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-menu-inner {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mobile-nav-link {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    padding: 8px 0;
    letter-spacing: -0.02em;
  }
  .mobile-nav-link:hover {
    color: var(--claude);
  }

  .mt-4 {
    margin-top: 16px;
    align-self: flex-start;
  }
</style>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  toggle?.addEventListener('click', () => {
    if (!menu) return;
    const isHidden = menu.hasAttribute('hidden');
    if (isHidden) {
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-label', 'Fechar menu');
    } else {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-label', 'Abrir menu');
    }
  });
</script>
