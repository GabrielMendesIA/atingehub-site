---
interface Props {
  size?: number;
  glow?: boolean;
  variant?: 'light' | 'dark';
}
const { size = 40, glow = false, variant = 'light' } = Astro.props;

const mountainMain = variant === 'light' ? '#F5F3EE' : '#0A0A0A';
const mountainSide = variant === 'light' ? '#8A8A8A' : '#8A8A8A';
const mountainBack = variant === 'light' ? '#4A4A4A' : '#4A4A4A';
---

<svg
  width={size}
  height={Math.round(size * 0.8)}
  viewBox="0 0 100 80"
  fill="none"
  aria-label="AtingeHUB"
  class:list={[glow ? 'logo-glow' : '']}
>
  <title>AtingeHUB</title>
  <path d="M16 64L28 42L40 64Z" fill={mountainBack} />
  <path d="M60 64L74 38L88 64Z" fill={mountainSide} />
  <path d="M24 64L50 16L76 64Z" fill={mountainMain} />
  <path d="M50 16L50 6" stroke="#D97757" stroke-width="2" />
  <path d="M50 7L58 9L50 12Z" fill="#D97757" />
</svg>

<style>
  .logo-glow {
    filter: drop-shadow(0 0 18px rgba(217, 119, 87, 0.5));
  }
</style>
