---
import { whatsappLink } from '../config/site';
import LogoMark from './LogoMark.astro';

interface Props {
  title?: string;
  body?: string;
  message?: string;
  cta?: string;
}

const {
  title = 'Conversa de 20 minutos, <em>sem compromisso.</em>',
  body = 'Me conta a dor concreta do seu negócio. Se a AtingeHUB não for o caminho, te indico quem é. Se for, a gente já alinha os próximos passos.',
  message,
  cta = '$ iniciar conversa →',
} = Astro.props;
---

<section class="wa-cta">
  <div class="container-page wa-inner">
    <div class="wa-text">
      <p class="eyebrow"><span class="accent">●</span> Próximo passo</p>
      <h2 class="wa-title" set:html={title} />
      <p class="wa-body">{body}</p>
    </div>
    <div class="wa-side">
      <LogoMark size={48} glow />
      <a
        href={whatsappLink(message)}
        target="_blank"
        rel="noopener"
        class="btn btn-primary"
      >
        {cta}
      </a>
    </div>
  </div>
</section>

<style>
  .wa-cta {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: var(--space-16) 0;
    margin-top: var(--space-16);
    background: var(--bg-soft);
    position: relative;
    overflow: hidden;
  }
  .wa-cta::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse, var(--claude-glow-soft), transparent 70%);
    pointer-events: none;
  }

  .wa-inner {
    display: grid;
    gap: 32px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .wa-inner {
      grid-template-columns: 1fr auto;
      gap: 64px;
    }
  }

  .wa-title {
    margin-top: 12px;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.1;
  }
  .wa-body {
    margin-top: 16px;
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.7;
    max-width: 580px;
  }

  .wa-side {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }
  @media (min-width: 768px) {
    .wa-side {
      align-items: center;
    }
  }
</style>
