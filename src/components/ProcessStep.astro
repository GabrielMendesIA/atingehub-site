---
interface Props {
  num: string;
  title: string;
  description: string;
}
const { num, title, description } = Astro.props;
---

<div class="step">
  <div class="step-num">{num}</div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .step {
    padding: 28px 24px;
    text-align: left;
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    letter-spacing: 1.5px;
    margin-bottom: 18px;
  }
  h3 {
    font-size: 19px;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--text);
  }
  p {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--text-muted);
  }
</style>
