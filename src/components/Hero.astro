---
import { whatsappLink } from '../config/site';
import LogoMark from './LogoMark.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string; external?: boolean };
  secondaryCta?: { label: string; href: string };
  withLogoMark?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta = {
    label: '$ iniciar conversa',
    href: whatsappLink(),
    external: true,
  },
  secondaryCta,
  withLogoMark = false,
} = Astro.props;
---

<section class="hero">
  <div class="container-page">
    {withLogoMark && (
      <div class="hero-mark">
        <LogoMark size={56} glow />
      </div>
    )}
    {eyebrow && (
      <p class="eyebrow">
        <span class="accent">●</span> {eyebrow}
      </p>
    )}
    <h1 class="hero-title" set:html={title} />
    {subtitle && <p class="hero-subtitle" set:html={subtitle} />}
    <div class="hero-ctas">
      <a
        href={primaryCta.href}
        target={primaryCta.external ? '_blank' : undefined}
        rel={primaryCta.external ? 'noopener' : undefined}
        class="btn btn-primary"
      >
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class="btn btn-ghost">
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 110px 0 70px;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 70px 0 50px;
    }
  }

  .hero-mark {
    margin-bottom: 24px;
  }

  .hero-title {
    margin-top: 20px;
    max-width: 920px;
    font-size: clamp(40px, 5.5vw, 76px);
  }

  .hero-subtitle {
    margin-top: 22px;
    color: var(--text-muted);
    font-size: 17px;
    line-height: 1.7;
    max-width: 660px;
  }
  .hero-subtitle :global(strong) {
    color: var(--text);
    font-weight: 500;
  }

  .hero-ctas {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
</style>
