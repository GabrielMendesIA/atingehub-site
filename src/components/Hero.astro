---
interface Props {
  eyebrow?: string;
  titleStart: string;
  rotatingWords: string[];
  titleEnd?: string;
  subtitle: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  eyebrow,
  titleStart,
  rotatingWords,
  titleEnd,
  subtitle,
  primaryCta,
  secondaryCta,
} = Astro.props;
---

<section class="hero">
  <div class="container-page">
    {eyebrow && <p class="eyebrow hero-eyebrow">{eyebrow}</p>}
    <h1 class="hero-title">
      {titleStart}
      <span class="rotating" data-words={JSON.stringify(rotatingWords)}>
        <em>{rotatingWords[0]}</em>
      </span>
      {titleEnd && <><br />{titleEnd}</>}
    </h1>
    <p class="hero-subtitle" set:html={subtitle} />

    {(primaryCta || secondaryCta) && (
      <div class="hero-ctas">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn-primary">
            {primaryCta.label}
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-ghost">
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    padding: 40px 0 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, var(--accent-glow), transparent 70%);
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }
  .hero > .container-page {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .hero { padding: 24px 0 60px; }
  }

  .hero-eyebrow { margin-bottom: 22px; display: inline-block; }

  .hero-title {
    font-size: clamp(40px, 6.8vw, 84px);
    line-height: 1;
    letter-spacing: -0.04em;
    max-width: 900px;
    margin: 0 auto;
  }

  .rotating {
    display: inline-block;
    min-width: 0.5em;
  }
  .rotating em {
    display: inline-block;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .hero-subtitle {
    margin: 28px auto 0;
    max-width: 600px;
    font-size: 17px;
    line-height: 1.65;
    color: var(--text-muted);
  }
  .hero-subtitle :global(strong) {
    color: var(--text);
    font-weight: 500;
  }

  .hero-ctas {
    margin-top: 36px;
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }
</style>

<script>
  const el = document.querySelector('.rotating');
  if (el) {
    const words: string[] = JSON.parse(el.getAttribute('data-words') || '[]');
    const em = el.querySelector('em');
    if (em && words.length > 1) {
      let i = 0;
      setInterval(() => {
        em.style.opacity = '0';
        em.style.transform = 'translateY(-6px)';
        setTimeout(() => {
          i = (i + 1) % words.length;
          em.textContent = words[i];
          em.style.opacity = '1';
          em.style.transform = 'translateY(0)';
        }, 400);
      }, 2400);
    }
  }
</script>
