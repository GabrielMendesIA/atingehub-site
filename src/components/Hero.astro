---
import { whatsappLink } from '../config/site';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string; external?: boolean };
  secondaryCta?: { label: string; href: string };
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta = {
    label: 'Falar no WhatsApp',
    href: whatsappLink(),
    external: true,
  },
  secondaryCta,
} = Astro.props;
---

<section class="hero">
  <div class="container-page">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="hero-title" set:html={title} />
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    <div class="hero-ctas">
      <a
        href={primaryCta.href}
        target={primaryCta.external ? '_blank' : undefined}
        rel={primaryCta.external ? 'noopener' : undefined}
        class="btn btn-primary"
      >
        {primaryCta.label}
      </a>
      {secondaryCta && (
        <a href={secondaryCta.href} class="btn btn-ghost">
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-24) 0 var(--space-16);
  }
  .hero-title {
    margin-top: 0.75rem;
    max-width: 52rem;
  }
  .hero-title :global(em) {
    font-style: italic;
    color: var(--color-accent-strong);
  }
  .hero-subtitle {
    margin-top: 1.25rem;
    font-size: 1.125rem;
    color: var(--color-ink-soft);
    max-width: 42rem;
    line-height: 1.6;
  }
  .hero-ctas {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
