---
const pilares = [
  {
    eyebrow: '01 · Sistema',
    title: 'Sistema, <em>não chatbot.</em>',
    body: 'Cada solução nasce de um problema concreto do seu negócio — não de catálogo de IA pronto. O que entra na sua loja foi feito pra você, junto com você.',
    glow: 'var(--claude-glow)',
  },
  {
    eyebrow: '02 · Humano',
    title: 'Relação <em>primeiro.</em>',
    body: 'A IA é extensão de quem você é, nunca substituto. Quem conduz o relacionamento com seu cliente continua sendo você — a IA só remove fricção.',
    glow: 'var(--cerebro-glow)',
  },
  {
    eyebrow: '03 · Dono',
    title: 'Você fica <em>com tudo.</em>',
    body: 'Dados, código, infraestrutura. Stack 100% aberta ou self-hosted. Sem lock-in, sem dependência. Se um dia quiser tocar sozinho, consegue.',
    glow: 'var(--cadencia-glow)',
  },
];
---

<section class="row manifesto">
  <div class="container-page">
    <div class="row-header">
      <span class="num">01</span>
      <h2>Princípios não-negociáveis</h2>
    </div>
    <p class="sub">3 regras que sustentam toda decisão</p>

    <div class="pilares">
      {pilares.map((p) => (
        <div class="glow-card pilar" style={`--glow: ${p.glow}`}>
          <p class="eyebrow">{p.eyebrow}</p>
          <h3 class="pilar-title" set:html={p.title} />
          <p class="pilar-body">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .manifesto {
    padding-top: 80px;
  }

  .pilares {
    margin-top: 32px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .pilares {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pilar {
    padding: 32px 28px;
    min-height: 240px;
  }

  .pilar-title {
    margin-top: 14px;
    font-size: 24px;
    line-height: 1.2;
  }
  .pilar-body {
    margin-top: 14px;
    color: var(--text-muted);
    font-size: 14.5px;
    line-height: 1.65;
  }
</style>
