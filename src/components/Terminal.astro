---
interface Line {
  type?: 'comm' | 'ok' | 'var' | 'plain';
  prompt?: string;
  text: string;
  tail?: string;
  tailType?: 'ok' | 'var' | 'comm';
}

interface Props {
  lines: Line[];
  cursor?: boolean;
  title?: string;
}

const { lines, cursor = true, title } = Astro.props;
---

<div class="terminal">
  <div class="term-head">
    <div class="dots">
      <span class="r"></span>
      <span class="y"></span>
      <span class="g"></span>
    </div>
    {title && <span class="term-title">{title}</span>}
  </div>
  <div class="term-body">
    {lines.map((line) => (
      <div class="line">
        {line.prompt && <span class="prompt">{line.prompt}</span>}
        {line.type === 'comm' && <span class="comm">{line.text}</span>}
        {line.type === 'ok' && <span class="ok">{line.text}</span>}
        {line.type === 'var' && <span class="var">{line.text}</span>}
        {(line.type === undefined || line.type === 'plain') && <span>{line.text}</span>}
        {line.tail && (
          <span class:list={[line.tailType || 'plain']}>{` ${line.tail}`}</span>
        )}
      </div>
    ))}
    {cursor && (
      <div class="line">
        <span class="prompt">$</span><span class="caret">&nbsp;</span>
      </div>
    )}
  </div>
</div>

<style>
  .terminal {
    background: #0E0E12;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  }

  .term-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    background: rgba(255, 255, 255, 0.025);
    border-bottom: 1px solid var(--border);
  }
  .dots {
    display: flex;
    gap: 6px;
  }
  .dots span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dots span.r { background: #ff5f57; }
  .dots span.y { background: #ffbd2e; }
  .dots span.g { background: #28c93f; }

  .term-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.5px;
  }

  .term-body {
    padding: 20px 22px 22px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.95;
    color: var(--text-muted);
  }
  @media (max-width: 600px) {
    .term-body { font-size: 12px; padding: 16px 18px 18px; }
  }

  .line { display: block; word-break: break-word; }
  .prompt { color: var(--accent); margin-right: 8px; }
  .ok { color: var(--success); }
  .var { color: var(--cerebro); }
  .comm { color: var(--text-dim); }

  .caret {
    display: inline-block;
    width: 8px;
    height: 1.05em;
    background: var(--accent);
    vertical-align: -2px;
    margin-left: 2px;
    animation: blink 1s steps(2) infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
</style>
