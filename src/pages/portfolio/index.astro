---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';
import { whatsappLink } from '../../config/site';

const products = (await getCollection('products')).sort(
  (a, b) => a.data.order - b.data.order
);

const combos = [
  {
    name: 'Presença',
    products: ['Vitrine', 'Cérebro'],
    gain: 'Site captura leads e os joga direto num cérebro organizado da empresa. Equipe nova aprende rápido com base consultável em português, e nenhuma informação se perde entre quem entra e quem sai.',
    discount: '-10%',
    glow: 'var(--vitrine-glow)',
  },
  {
    name: 'Conversão',
    products: ['Vitrine', 'Engrenagens', 'Balcão'],
    gain: 'Lead entra pela página, é enriquecido e segmentado na automação, e cai no painel único com histórico completo. Circuito de captura → atendimento fechado, zero contato perdido na passagem entre ferramentas.',
    discount: '-15%',
    glow: 'var(--engrenagens-glow)',
  },
  {
    name: 'Atendimento',
    products: ['Balcão', 'Voz', 'Cadência'],
    gain: 'IA atende o volume simples 24/7, humano entra no mesmo painel quando precisa, e a automação dispara remarketing seguindo o cliente pós-venda. Atendimento que não dorme, não esquece, e não depende da memória de quem está no plantão.',
    discount: '-15%',
    glow: 'var(--balcao-glow)',
  },
  {
    name: 'Operação IA',
    products: ['Bancada', 'Cadência', 'Voz'],
    gain: 'Agentes internos preparam o que a IA de atendimento precisa saber, automações executam tarefas repetitivas, e o dono sai do gargalo. Performance sobe na operação interna e na relação com o cliente ao mesmo tempo.',
    discount: '-15%',
    glow: 'var(--cerebro-glow)',
  },
  {
    name: 'Sistema completo',
    products: ['Vitrine', 'Cérebro', 'Bancada', 'Engrenagens', 'Balcão', 'Voz'],
    gain: 'Cada produto alimenta o próximo: conhecimento do negócio vira contexto dos agentes, que refinam as automações, que populam o CRM, que entrega ao cliente via IA, tudo publicado num canal próprio. O ganho não é soma, é multiplicação — porque a IA aprende com o todo.',
    discount: '-25%',
    glow: 'var(--claude-glow)',
  },
];

const steps = [
  {
    num: '01',
    title: 'Conversa de 20 min',
    desc: 'Você me manda mensagem no WhatsApp contando qual é a dor principal da empresa hoje. Sem pitch, sem formulário.',
  },
  {
    num: '02',
    title: 'Diagnóstico 1h',
    desc: 'Mapa do negócio, onde está o gargalo, qual produto resolve primeiro. Demo ao vivo do Açaí Algomais se fizer sentido.',
  },
  {
    num: '03',
    title: 'Implementação',
    desc: '1 call por semana, tarefa entre calls, entregável no prazo. 2 a 6 semanas por produto. Você aprende fazendo.',
  },
  {
    num: '04',
    title: 'Depoimento + upsell',
    desc: 'Produto entregue, depoimento seu. Se quiser avançar pro próximo, a gente volta pra reunião considerando o que já está rodando e o próximo ganho possível.',
  },
];

const portfolioJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.data.name,
    description: p.data.slogan,
    url: `https://atingehub.com/portfolio/${p.data.slug || p.id}`,
  })),
};
---

<BaseLayout
  title="Portfólio"
  description="8 produtos AtingeHUB para varejo brasileiro: Vitrine, Cérebro, Bancada, Engrenagens, Cadência, Balcão, Voz, Bússola. Vendidos isolados ou em combo."
  jsonLd={portfolioJsonLd}
>
  <section class="hero">
    <div class="container-page">
      <p class="eyebrow"><span class="accent">●</span> Portfólio</p>
      <h1 class="hero-title">
        8 produtos.<br /><em>1 sistema.</em>
      </h1>
      <p class="hero-subtitle">
        Cada produto resolve uma <strong>dor concreta da operação</strong>. A ordem de implementação e o investimento saem da reunião de dimensionamento — analisamos sua empresa, ponto de partida, e ritmo que faz sentido. Abaixo, os 8 produtos por <strong>nível de profundidade</strong>: começa pelo que dá resultado visível rápido e vai aprofundando até virar sistema operacional.
      </p>
      <div class="hero-ctas">
        <a href={whatsappLink('Quero marcar a reunião de dimensionamento do portfólio')} target="_blank" rel="noopener" class="btn btn-primary">
          $ marcar dimensionamento →
        </a>
      </div>
    </div>
  </section>

  <section class="row produtos-section">
    <div class="container-page">
      <div class="row-header">
        <span class="num">01</span>
        <h2>Os 8 produtos</h2>
      </div>
      <p class="sub">Operacional · Inteligência · Estratégico</p>
      <p class="lead">
        Vendidos isolados ou em combo. Clique em cada um pra ver ferramenta-base, problema que resolve, entregável palpável, e modelo comercial.
      </p>

      <div class="product-grid">
        {products.map((p) => (
          <ProductCard
            name={p.data.name}
            slug={p.data.slug || p.id}
            slogan={p.data.slogan}
            summary={p.data.summary}
            family={p.data.family}
            href={`/portfolio/${p.data.slug || p.id}`}
            accentColor={p.data.accent_color}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="row combos-section">
    <div class="container-page">
      <div class="row-header">
        <span class="num">02</span>
        <h2>Combos · como os produtos conversam</h2>
      </div>
      <p class="sub">Módulo solto resolve um pedaço · módulo combinado resolve um processo</p>
      <p class="lead">
        Cada peça alimenta a próxima e a IA aprende com o todo. As combinações abaixo são <strong>referências</strong> — a desenhada pra sua empresa sai da reunião, depois do diagnóstico.
      </p>

      <div class="combos-grid">
        {combos.map((combo) => (
          <div class="glow-card combo-card" style={`--glow: ${combo.glow}`}>
            <div class="combo-head">
              <p class="eyebrow"><span class="accent">●</span> Combo {combo.discount}</p>
              <h3 class="combo-name">{combo.name}</h3>
            </div>
            <div class="combo-products">
              {combo.products.map((name) => (
                <span class="combo-chip">{name}</span>
              ))}
            </div>
            <p class="combo-gain">{combo.gain}</p>
          </div>
        ))}
      </div>

      <p class="combo-note">
        <strong>Sem pacote engessado.</strong> As combinações são referências de como os produtos conversam entre si — a composição certa pra sua empresa (quais produtos, em qual ordem, com qual profundidade) é desenhada na reunião, depois do diagnóstico da operação, dor principal e ritmo que faz sentido pra você.
      </p>
    </div>
  </section>

  <section class="row processo-section">
    <div class="container-page">
      <div class="row-header">
        <span class="num">03</span>
        <h2>Como funciona</h2>
      </div>
      <p class="sub">20 min · 1h · 2 a 6 semanas por produto · depoimento</p>

      <div class="steps">
        {steps.map((step) => (
          <div class="step">
            <div class="step-num">{step.num}</div>
            <h4 class="step-title">{step.title}</h4>
            <p class="step-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <WhatsAppCTA
    title="Quer ver a <em>combinação certa</em> pro seu negócio?"
    body="Conversa de 20 minutos no WhatsApp. Te conto qual produto começa primeiro e por quê, baseado na dor que você trouxer."
  />
</BaseLayout>

<style>
  .hero {
    padding: 60px 0 50px;
  }
  .hero-title {
    margin-top: 18px;
    font-size: clamp(40px, 6vw, 76px);
    line-height: 1.02;
  }
  .hero-subtitle {
    margin-top: 22px;
    color: var(--text-muted);
    font-size: 16.5px;
    line-height: 1.75;
    max-width: 720px;
  }
  .hero-subtitle strong {
    color: var(--text);
    font-weight: 500;
  }
  .hero-ctas {
    margin-top: 32px;
  }

  .product-grid {
    margin-top: 36px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .product-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .combos-grid {
    margin-top: 32px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .combos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .combos-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .combo-card:last-child {
      grid-column: span 3;
    }
  }

  .combo-card {
    padding: 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .combo-name {
    margin-top: 6px;
    font-size: 28px;
    line-height: 1.05;
  }
  .combo-products {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .combo-chip {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text);
    padding: 6px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.02);
  }
  .combo-gain {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.7;
  }

  .combo-note {
    margin-top: 32px;
    padding: 24px 26px;
    border-left: 3px solid var(--claude);
    background: var(--bg-soft);
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.7;
  }
  .combo-note strong {
    color: var(--text);
    font-weight: 500;
  }

  .steps {
    margin-top: 36px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
    counter-reset: step;
  }
  @media (min-width: 640px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .steps {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .step {
    padding: 28px 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition: border-color 0.25s;
  }
  .step:hover {
    border-color: var(--border-strong);
  }
  .step-num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 1.5px;
    color: var(--claude);
  }
  .step-title {
    margin-top: 10px;
    font-size: 20px;
    line-height: 1.2;
  }
  .step-desc {
    margin-top: 10px;
    color: var(--text-muted);
    font-size: 13.5px;
    line-height: 1.65;
  }
</style>
