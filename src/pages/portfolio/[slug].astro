---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';
import ProductCard from '../../components/ProductCard.astro';
import { whatsappLink, site } from '../../config/site';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.data.slug || product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const allProducts = (await getCollection('products')).sort(
  (a, b) => a.data.order - b.data.order
);

const related = allProducts
  .filter((p) => (p.data.slug || p.id) !== (product.data.slug || product.id))
  .slice(0, 3);

const familyLabel = {
  operacional: 'Operacional',
  inteligencia: 'Inteligência',
  estrategico: 'Estratégico',
}[product.data.family];

const versatilityLabel = {
  baixa: 'Baixa',
  media: 'Média',
  alta: 'Alta',
  'muito-alta': 'Muito alta',
}[product.data.versatility];

const accent = product.data.accent_color || `var(--${product.data.slug || product.id})`;
const glow = `var(--${product.data.slug || product.id}-glow)`;

const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: product.data.name,
  description: product.data.summary,
  provider: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  areaServed: site.contact.region.map((c) => ({ '@type': 'City', name: c })),
};

const slug = product.data.slug || product.id;
---

<BaseLayout
  title={product.data.seo.title}
  description={product.data.seo.description}
  jsonLd={productJsonLd}
  productContext={slug}
>
  <section class="product-hero" data-product={slug}>
    <div class="container-page hero-grid">
      <div class="hero-text">
        <p class="eyebrow"><span class="accent" style={`color: ${accent}`}>●</span> {familyLabel} · {product.data.name}</p>
        <h1 class="product-title">{product.data.name}<span class="dot" style={`color: ${accent}`}>.</span></h1>
        <p class="product-slogan">{product.data.slogan}</p>
        <p class="product-summary">{product.data.summary}</p>
        <div class="hero-ctas">
          <a
            href={whatsappLink(`Quero conversar sobre o módulo ${product.data.name}`)}
            target="_blank"
            rel="noopener"
            class="btn btn-primary"
          >
            $ conversar sobre {product.data.name.toLowerCase()} →
          </a>
          <a href="/portfolio" class="btn btn-ghost">ver portfólio</a>
        </div>
      </div>
      <div class="hero-badge">
        <img
          src={`/brand/badges/${slug}.svg`}
          alt={`Badge ${product.data.name}`}
          width="200"
          height="200"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="row spec-section">
    <div class="container-page">
      <div class="spec-grid">
        <div class="glow-card spec-card" style={`--glow: ${glow}`}>
          <p class="eyebrow"><span class="accent" style={`color: ${accent}`}>01</span> Ferramenta-base</p>
          <p class="spec-body">{product.data.tool_base}</p>
        </div>
        <div class="glow-card spec-card" style={`--glow: ${glow}`}>
          <p class="eyebrow"><span class="accent" style={`color: ${accent}`}>02</span> Problema que resolve</p>
          <p class="spec-body">{product.data.problem}</p>
        </div>
        <div class="glow-card spec-card" style={`--glow: ${glow}`}>
          <p class="eyebrow"><span class="accent" style={`color: ${accent}`}>03</span> Entregável palpável</p>
          <p class="spec-body">{product.data.deliverable}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="row prose-section">
    <div class="container-page">
      <div class="prose-grid">
        <article class="prose">
          <Content />
        </article>
        <aside class="prose-aside">
          <div class="glow-card aside-card" style={`--glow: ${glow}`}>
            <p class="eyebrow"><span class="accent" style={`color: ${accent}`}>●</span> Modelo comercial</p>
            <dl class="aside-dl">
              {product.data.pricing.oneshot && (
                <>
                  <dt>One-shot</dt>
                  <dd>{product.data.pricing.oneshot}</dd>
                </>
              )}
              {product.data.pricing.monthly && (
                <>
                  <dt>{product.data.pricing.monthly_required ? 'Mensal obrigatória' : 'Mensal opcional'}</dt>
                  <dd>{product.data.pricing.monthly}</dd>
                </>
              )}
              <dt>Vendido isolado</dt>
              <dd>{product.data.sold_alone ? 'Sim' : 'Não — exige produto pré-requisito'}</dd>
              <dt>Versatilidade</dt>
              <dd>{versatilityLabel}</dd>
              {product.data.dependencies.length > 0 && (
                <>
                  <dt>Pré-requisitos</dt>
                  <dd>{product.data.dependencies.join(', ')}</dd>
                </>
              )}
            </dl>
            <p class="aside-note">
              Preços de referência — valor final sai na <a href={whatsappLink()} target="_blank" rel="noopener">reunião de dimensionamento</a>.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="row related-section">
    <div class="container-page">
      <div class="row-header">
        <span class="num">04</span>
        <h2>Outros produtos que combinam</h2>
      </div>
      <p class="sub">{product.data.name} fica mais forte com</p>

      <div class="related-grid">
        {related.map((p) => (
          <ProductCard
            name={p.data.name}
            slug={p.data.slug || p.id}
            slogan={p.data.slogan}
            summary={p.data.summary}
            family={p.data.family}
            href={`/portfolio/${p.data.slug || p.id}`}
            accentColor={p.data.accent_color}
          />
        ))}
      </div>

      <div class="related-cta">
        <a href="/portfolio" class="btn btn-ghost">ver todos os 8 produtos →</a>
      </div>
    </div>
  </section>

  <WhatsAppCTA
    title={`Quer conversar sobre ${product.data.name}?`}
    message={`Quero conversar sobre o módulo ${product.data.name}`}
  />
</BaseLayout>

<style>
  .product-hero {
    padding: 50px 0 40px;
    position: relative;
    overflow: hidden;
  }
  .product-hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 80vw;
    height: 80vh;
    background: radial-gradient(ellipse, var(--product-glow, var(--claude-glow)), transparent 60%);
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }
  .product-hero .container-page {
    position: relative;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    gap: 48px;
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: 1.4fr 1fr;
      gap: 72px;
    }
  }

  .product-title {
    margin-top: 16px;
    font-size: clamp(48px, 7vw, 88px);
    line-height: 1;
  }
  .product-slogan {
    margin-top: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 26px);
    color: var(--text);
    line-height: 1.35;
    max-width: 600px;
  }
  .product-summary {
    margin-top: 18px;
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.7;
    max-width: 600px;
  }
  .hero-ctas {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-badge {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-badge img {
    width: 200px;
    height: 200px;
    filter: drop-shadow(0 0 32px var(--product-glow, var(--claude-glow)));
  }

  /* Spec section ─────────────────────────────────────── */
  .spec-section {
    padding-top: 40px;
  }
  .spec-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .spec-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .spec-card {
    padding: 26px 24px;
  }
  .spec-body {
    margin-top: 14px;
    color: var(--text-muted);
    font-size: 14.5px;
    line-height: 1.7;
  }

  /* Prose section ────────────────────────────────────── */
  .prose-section {
    padding-top: 60px;
  }
  .prose-grid {
    display: grid;
    gap: 48px;
  }
  @media (min-width: 960px) {
    .prose-grid {
      grid-template-columns: 1.5fr 1fr;
      gap: 64px;
    }
  }

  .prose :global(h2) {
    margin-top: 0;
    font-size: clamp(28px, 3.2vw, 40px);
    line-height: 1.1;
  }
  .prose :global(h3) {
    margin-top: 36px;
    font-size: 22px;
    line-height: 1.2;
  }
  .prose :global(p) {
    margin-top: 18px;
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.75;
  }
  .prose :global(p strong) {
    color: var(--text);
    font-weight: 500;
  }
  .prose :global(em) {
    color: var(--claude);
  }
  .prose :global(ul) {
    margin-top: 16px;
    padding-left: 22px;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 15px;
    line-height: 1.7;
  }
  .prose :global(li) {
    list-style: disc;
  }
  .prose :global(li strong),
  .prose :global(li code) {
    color: var(--text);
  }
  .prose :global(hr) {
    margin: 48px 0;
    border: none;
    border-top: 1px solid var(--border);
  }
  .prose :global(pre) {
    margin-top: 22px;
    padding: 22px 24px;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.75;
    color: var(--text-muted);
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .prose :global(p code),
  .prose :global(li code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: rgba(255, 255, 255, 0.06);
    padding: 1px 6px;
    border-radius: 3px;
    color: var(--text);
  }
  .prose :global(blockquote) {
    margin-top: 22px;
    padding: 16px 22px;
    border-left: 3px solid var(--product-color, var(--claude));
    background: var(--bg-soft);
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.7;
  }
  .prose :global(blockquote p) {
    margin-top: 0;
  }

  /* Aside ─────────────────────────────────────────────── */
  .prose-aside {
    align-self: start;
  }
  .aside-card {
    padding: 26px 24px;
    position: sticky;
    top: 100px;
  }
  .aside-dl {
    margin-top: 14px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .aside-dl dt {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-dim);
  }
  .aside-dl dd {
    margin-top: 4px;
    color: var(--text);
    font-size: 15px;
    line-height: 1.5;
  }
  .aside-note {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    font-size: 12.5px;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .aside-note a {
    color: var(--claude);
  }

  /* Related products ─────────────────────────────────── */
  .related-section {
    padding-top: 60px;
  }
  .related-grid {
    margin-top: 32px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .related-cta {
    margin-top: 36px;
  }
</style>
