---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import ProductCard from '../components/ProductCard.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import Terminal from '../components/Terminal.astro';
import { site } from '../config/site';

const products = (await getCollection('products')).sort(
  (a, b) => a.data.order - b.data.order
);

const homeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.description,
  publisher: { '@type': 'Organization', name: site.name },
};

const terminalLines = [
  { type: 'comm', text: '// implementação acompanhada' },
  { prompt: '$', text: 'atingehub --deploy ia-no-seu-negocio' },
  { type: 'comm', text: '→ carregando ferramentas', tail: '[obsidian, claude, n8n, chatwoot]', tailType: 'var' },
  { type: 'comm', text: '→ conectando whatsapp ✓ crm ✓ cérebro ✓' },
  { type: 'ok', text: '✓ sistema rodando 24h · 8 produtos · 50+ habilidades' },
];
---

<BaseLayout description={site.description} jsonLd={homeJsonLd}>
  <section class="hero">
    <div class="container-page hero-grid">
      <div class="hero-text">
        <p class="eyebrow"><span class="accent">●</span> AtingeHUB · Sistemas de IA para varejo brasileiro</p>
        <h1 class="hero-title">
          Mérito,<br /><em>com pulso.</em>
        </h1>
        <p class="hero-subtitle">
          Uma <strong>IA rodando dentro do seu negócio</strong> — não um chatbot. 8 produtos que combinam como você precisa, com stack aberta e relação humana em primeiro lugar.
        </p>
        <div class="hero-ctas">
          <a href="https://wa.me/5515999999999" target="_blank" rel="noopener" class="btn btn-primary">
            $ iniciar conversa
          </a>
          <a href="/portfolio" class="btn btn-ghost">ver portfólio →</a>
        </div>
      </div>

      <div class="hero-terminal">
        <Terminal lines={terminalLines} />
      </div>
    </div>
  </section>

  <Manifesto />

  <section class="row portfolio-section">
    <div class="container-page">
      <div class="row-header">
        <span class="num">02</span>
        <h2>8 produtos · toolkit integrado</h2>
      </div>
      <p class="sub">Operacional · Inteligência · Estratégico</p>
      <p class="lead">
        Vendidos isolados ou em combo. Cada um resolve um problema concreto, com entregável palpável e prazo definido. Não é catálogo de IA — é sistema.
      </p>

      <div class="product-grid">
        {products.map((p) => (
          <ProductCard
            name={p.data.name}
            slug={p.data.slug || p.id}
            slogan={p.data.slogan}
            summary={p.data.summary}
            family={p.data.family}
            href={`/portfolio/${p.data.slug || p.id}`}
            accentColor={p.data.accent_color}
          />
        ))}
      </div>

      <div class="portfolio-cta">
        <a href="/portfolio" class="btn btn-ghost">ver portfólio completo →</a>
      </div>
    </div>
  </section>

  <section class="row process-teaser">
    <div class="container-page">
      <div class="row-header">
        <span class="num">03</span>
        <h2>Por que agora · a janela 2026-2028</h2>
      </div>
      <p class="sub">Atendimento · Campanhas · Decisão · Operação</p>
      <p class="lead">
        A vizinha do lado já começou. Tem janela aberta no varejo brasileiro pra entrar com IA enquanto isso ainda é diferencial — antes de virar commodity igual maquininha de cartão.
      </p>
      <a href="/por-que-agora" class="btn btn-ghost">por que agora →</a>
    </div>
  </section>

  <WhatsAppCTA />
</BaseLayout>

<style>
  .hero {
    padding: 100px 0 50px;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 60px 0 40px;
    }
  }

  .hero-grid {
    display: grid;
    gap: 56px;
    align-items: center;
  }
  @media (min-width: 1000px) {
    .hero-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 80px;
    }
  }

  .hero-title {
    margin-top: 24px;
    font-size: clamp(48px, 6.5vw, 84px);
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .hero-subtitle {
    margin-top: 24px;
    color: var(--text-muted);
    font-size: 17px;
    line-height: 1.7;
    max-width: 560px;
  }

  .hero-ctas {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-terminal {
    width: 100%;
  }

  .portfolio-section .lead,
  .process-teaser .lead {
    max-width: 720px;
  }

  .product-grid {
    margin-top: 36px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .product-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .portfolio-cta {
    margin-top: 36px;
  }
</style>
