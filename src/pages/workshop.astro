---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FAQ from '../components/FAQ.astro';
import WorkshopApplicationForm from '../components/WorkshopApplicationForm.astro';

const howItWorks = [
  {
    num: '01',
    title: 'Compra no site',
    description:
      'Pix ou cartão em até 12x. Confirmação automática em segundos. Você nem precisa esperar pra começar.',
  },
  {
    num: '02',
    title: 'Acesso ao GitHub na hora',
    description:
      'Convite pro repositório AtingeHUB Stack — 50+ skills prontas pra Claude Code. As skills são suas pra sempre, mesmo se nunca assistir o workshop.',
  },
  {
    num: '03',
    title: 'Workshop · gravado ou ao vivo',
    description:
      'Assiste a gravação na hora ou marca a próxima turma ao vivo. Você escolhe — e pode rever quantas vezes quiser.',
  },
  {
    num: '04',
    title: 'Instalação básica sozinho',
    description:
      'Documentação no próprio GitHub. Setup mínimo em 30 minutos. Travou? WhatsApp direto comigo no horário comercial.',
  },
];

const programa = [
  { time: '00:00–00:15', block: 'Boas-vindas e setup', body: 'Como o repositório está organizado, o que é Claude Code, qual stack você precisa ter rodando antes de começar.' },
  { time: '00:15–00:45', block: 'Os 4 pilares (Atendimento · Campanhas · Decisão · Operação)', body: 'O que cada um resolve no seu varejo, como as skills se conectam, exemplos de loja real.' },
  { time: '00:45–01:15', block: 'Demo ao vivo · agente Voz no Zap', body: 'Instalação do agente de atendimento no WhatsApp de teste. Treino com cardápio/serviço real. Você vê linha por linha do que precisa fazer.' },
  { time: '01:15–01:45', block: 'Demo ao vivo · Vault de conhecimento', body: 'Montagem ao vivo do vault Obsidian + Claude + NotebookLM. Como indexar documento da sua operação e consultar em linguagem natural.' },
  { time: '01:45–02:00', block: 'Q&A · sua dor concreta', body: 'Sessão aberta. Você manda a dor, eu mostro qual das 50+ skills resolve. Sem palestrinha de palco — direto na ferramenta.' },
];

const youGet = [
  {
    title: 'Acesso vitalício ao GitHub AtingeHUB Stack',
    body: '50+ skills prontas pra Claude Code · agentes, automações, workflows n8n, prompts. Updates do repositório incluídos enquanto a stack rodar.',
    accent: true,
  },
  {
    title: 'Workshop em vídeo · acesso vitalício',
    body: 'Gravação em alta qualidade pra rever quantas vezes precisar. Cada bloco capítulo separado, fácil de buscar.',
  },
  {
    title: '1 sessão ao vivo (opcional)',
    body: 'Se escolher o plano com ao vivo, entra na próxima turma agendada. Q&A aberto, dúvida direta comigo.',
  },
  {
    title: 'Documentação de instalação básica',
    body: 'Passo a passo escrito pra rodar a stack mínima em 30 minutos. Sem precisar adivinhar comando ou interpretar erro.',
  },
  {
    title: 'WhatsApp direto pra dúvida pontual',
    body: 'Travou na instalação? Manda print no Zap. Resposta em horário comercial — sem ticket, sem fila.',
  },
  {
    title: 'Mapa pessoal 8 produtos × suas dores',
    body: 'Curtinho. Quais das skills cruzam com o que mais aperta na sua operação hoje, em ordem de prioridade.',
  },
];

const faq = [
  {
    q: 'É ao vivo ou gravado?',
    a: 'Você escolhe. <strong>Gravado</strong> tem acesso imediato após o pagamento. <strong>Ao vivo</strong> entra na próxima turma agendada (datas confirmadas por email). Tem plano com os dois — gravação pra rever sempre + 1 sessão ao vivo pra Q&A direto.',
  },
  {
    q: 'Como funciona o acesso ao GitHub?',
    a: 'Após a confirmação do pagamento, eu adiciono seu usuário GitHub como colaborador do repositório <strong>AtingeHUB Stack</strong>. Você recebe o convite por email em até 1h em horário comercial. O acesso é vitalício e inclui updates futuros enquanto a stack continuar rodando.',
  },
  {
    q: 'Preciso saber programar?',
    a: 'Não pra usar as skills básicas. A instalação mínima é <strong>30 minutos de comandos copia-e-cola</strong> documentados no próprio repositório. Pra customização avançada, ajuda saber JavaScript/Python — mas não é pré-requisito.',
  },
  {
    q: 'E se eu travar na instalação?',
    a: 'Manda print no WhatsApp em horário comercial. Resposta em até 4h em dia útil. Sem ticket, sem fila, sem pacote de suporte caro pra contratar. <strong>Faz parte do acesso.</strong>',
  },
  {
    q: 'Posso assistir a gravação várias vezes?',
    a: 'Sim, acesso vitalício. Cada bloco é capítulo separado, com timestamps no descritivo — fácil pular pro pedaço que importa quando precisar refrescar.',
  },
  {
    q: 'Quem tem acesso aos updates do repositório?',
    a: 'Todo mundo que comprou o workshop. Enquanto eu mantiver a AtingeHUB Stack rodando — e ela está em desenvolvimento ativo — você recebe as novas skills no mesmo repositório, sem custo adicional.',
  },
  {
    q: 'Tem reembolso?',
    a: '7 dias após a compra. Se você acessou o GitHub e não viu valor, devolvo 100%. Depois disso, sem reembolso — porque o acesso ao repositório é o ativo principal e ele já é seu.',
  },
];
---

<BaseLayout
  title="Workshop"
  description="Workshop online — gravado ou ao vivo. Compra inclui acesso vitalício ao GitHub com 50+ skills AtingeHUB Stack. Você instala sozinho com documentação."
>
  <Hero
    eyebrow="Workshop online · 50+ skills no GitHub"
    titleStart="IA pro seu varejo, em"
    rotatingWords={['2 horas', 'uma noite', 'um sábado']}
    subtitle="Compra agora, recebe o <strong>repositório GitHub na hora</strong> com as 50+ skills da AtingeHUB Stack, e escolhe: <strong>gravado pra ver agora</strong> ou <strong>ao vivo na próxima turma</strong>."
    primaryCta={{ label: 'Comprar acesso', href: '#aplicar' }}
    secondaryCta={{ label: 'Ver o que tá incluso', href: '#tudo-incluso' }}
  />

  <section id="funciona" class="section">
    <div class="container-page">
      <div class="section-head">
        <span class="eyebrow">Como funciona</span>
        <h2>Da compra à IA rodando · 4 passos</h2>
      </div>
      <div class="how-grid">
        {howItWorks.map((s) => (
          <article class="how-card">
            <span class="how-num">{s.num}</span>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight roadmap-bg">
    <div class="container-page">
      <div class="section-head">
        <span class="eyebrow">Programa do workshop</span>
        <h2>5 blocos · 2 horas direto na ferramenta</h2>
        <p class="lead">
          0% slide motivacional. 100% Claude Code, n8n, Obsidian e Zap rodando na tela.
        </p>
      </div>
      <ol class="roadmap-list">
        {programa.map((r) => (
          <li class="rm-item">
            <span class="rm-time">{r.time}</span>
            <div>
              <h3>{r.block}</h3>
              <p>{r.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section id="tudo-incluso" class="section">
    <div class="container-page">
      <div class="section-head">
        <span class="eyebrow">O que tá incluso</span>
        <h2>O principal é o repositório · o resto é apoio</h2>
        <p class="lead">
          As 50+ skills no GitHub são <strong>o ativo</strong>. O workshop existe pra você ver elas funcionando e ganhar segurança pra instalar sozinho.
        </p>
      </div>
      <div class="get-grid">
        {youGet.map((it) => (
          <article class={`get-card ${it.accent ? 'get-accent' : ''}`}>
            {it.accent && <span class="get-badge">★ destaque</span>}
            <h3>{it.title}</h3>
            <p>{it.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-page">
      <div class="pricing">
        <span class="eyebrow">Investimento</span>
        <h2>3 opções · todas com GitHub vitalício</h2>
        <p class="pricing-product">Workshop online + 50+ skills da AtingeHUB Stack · pagamento Pix ou cartão</p>

        <div class="plans">
          <article class="plan">
            <h3 class="plan-name">Gravado</h3>
            <p class="plan-sub">Acesso imediato após pagamento</p>
            <p class="plan-price"><span class="plan-amount">R$ 297</span><span class="plan-period">à vista</span></p>
            <ul class="plan-list">
              <li>Acesso vitalício ao GitHub</li>
              <li>Gravação completa do workshop</li>
              <li>Documentação de instalação</li>
              <li>WhatsApp pra dúvida pontual</li>
            </ul>
          </article>

          <article class="plan plan-featured">
            <span class="plan-tag">mais escolhido</span>
            <h3 class="plan-name">Gravado + ao vivo</h3>
            <p class="plan-sub">Acesso imediato + 1 sessão ao vivo</p>
            <p class="plan-price"><span class="plan-amount">R$ 597</span><span class="plan-period">à vista</span></p>
            <ul class="plan-list">
              <li>Tudo do plano Gravado</li>
              <li><strong>+ 1 sessão ao vivo</strong> com Q&A direto</li>
              <li>Acesso à comunidade interna</li>
              <li>Bônus: 30 min 1-pra-1 comigo</li>
            </ul>
          </article>

          <article class="plan">
            <h3 class="plan-name">Ao vivo</h3>
            <p class="plan-sub">Próxima turma confirmada por email</p>
            <p class="plan-price"><span class="plan-amount">R$ 497</span><span class="plan-period">à vista</span></p>
            <ul class="plan-list">
              <li>Acesso vitalício ao GitHub</li>
              <li>1 sessão ao vivo + gravação dela</li>
              <li>Q&A direto na sua dor</li>
              <li>WhatsApp pra dúvida pontual</li>
            </ul>
          </article>
        </div>

        <p class="pricing-cta-line">
          Pagamento Pix tem 5% de desconto. Cartão parcela em até 12x. Reembolso 100% em 7 dias.
        </p>
        <a href="#aplicar" class="btn btn-primary pricing-cta">Escolher plano e comprar</a>
      </div>
    </div>
  </section>

  <section class="section-tight faq-bg">
    <div class="container-page">
      <div class="section-head">
        <span class="eyebrow">Perguntas frequentes</span>
        <h2>Tira a dúvida antes de comprar</h2>
      </div>
      <FAQ items={faq} />
    </div>
  </section>

  <div id="aplicar">
    <WorkshopApplicationForm />
  </div>
</BaseLayout>

<style>
  .how-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: 1fr;
    max-width: 1000px;
    margin: 0 auto;
  }
  @media (min-width: 600px) {
    .how-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .how-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .how-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
  }
  .how-card .how-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 1.5px;
    margin-bottom: 14px;
    display: inline-block;
  }
  .how-card h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--text);
  }
  .how-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .roadmap-bg {
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .roadmap-list {
    list-style: none;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rm-item {
    display: grid;
    gap: 12px;
    padding: 20px 22px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  @media (min-width: 600px) {
    .rm-item { grid-template-columns: 140px 1fr; gap: 24px; }
  }
  .rm-time {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    letter-spacing: 0.5px;
    padding-top: 2px;
  }
  .rm-item h3 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--text);
  }
  .rm-item p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .get-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
    max-width: 1080px;
    margin: 0 auto;
  }
  @media (min-width: 600px) {
    .get-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .get-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .get-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 22px 22px;
    position: relative;
  }
  .get-accent {
    border-color: var(--accent);
    background: linear-gradient(180deg, var(--accent-soft), var(--bg-card) 60%);
  }
  .get-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .get-card h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--text);
    font-family: var(--font-sans);
    letter-spacing: -0.005em;
  }
  .get-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  /* ─── Pricing com 3 planos ──────────────────────────── */
  .pricing {
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
  }
  .pricing .eyebrow {
    margin-bottom: 14px;
    display: inline-block;
  }
  .pricing h2 {
    margin-bottom: 8px;
  }
  .pricing-product {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 40px;
  }

  .plans {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 32px;
    text-align: left;
  }
  @media (min-width: 900px) {
    .plans { grid-template-columns: repeat(3, 1fr); }
  }
  .plan {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }
  .plan:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .plan-featured {
    border-color: var(--accent);
    background: linear-gradient(180deg, var(--accent-soft), var(--bg-card) 30%);
    box-shadow: 0 12px 36px rgba(217, 119, 87, 0.18);
  }
  .plan-tag {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: white;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }
  .plan-name {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }
  .plan-sub {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }
  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 22px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--border);
  }
  .plan-amount {
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .plan-period {
    font-size: 13px;
    color: var(--text-dim);
  }
  .plan-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .plan-list li {
    padding-left: 22px;
    position: relative;
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .plan-list li::before {
    content: '✓';
    color: var(--accent);
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-weight: 700;
  }
  .plan-list li strong {
    color: var(--text);
    font-weight: 500;
  }

  .pricing-cta-line {
    font-size: 13px;
    color: var(--text-dim);
    margin-bottom: 20px;
  }
  .pricing-cta {
    padding: 16px 32px;
    justify-content: center;
  }

  .faq-bg {
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
</style>
