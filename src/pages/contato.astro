---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import LogoMark from '../components/LogoMark.astro';
import { site, whatsappLink } from '../config/site';

const terminalLines = [
  { type: 'comm', text: '// canal direto' },
  { prompt: '$', text: 'atingehub --contato' },
  { type: 'comm', text: '→ whatsapp 4h em dia útil ✓' },
  { type: 'comm', text: '→ email pra proposta formal ✓' },
  { type: 'ok', text: '✓ pronto · sem compromisso · 20 minutos' },
];
---

<BaseLayout
  title="Contato"
  description={`Falar com a ${site.name}. WhatsApp ${site.contact.whatsappLabel}, e-mail ${site.contact.email}. Atende em ${site.contact.region.slice(0, 3).join(', ')}.`}
>
  <section class="hero">
    <div class="container-page hero-grid">
      <div>
        <div class="hero-mark"><LogoMark size={56} glow /></div>
        <p class="eyebrow"><span class="accent">●</span> Contato</p>
        <h1 class="hero-title">
          Conversa de 20 minutos,<br /><em>sem compromisso.</em>
        </h1>
        <p class="hero-subtitle">
          Me conta a <strong>dor concreta</strong> do seu negócio. Se a AtingeHUB não for o caminho, te indico quem é. Se for, a gente já alinha os próximos passos.
        </p>
        <div class="hero-ctas">
          <a href={whatsappLink()} target="_blank" rel="noopener" class="btn btn-primary">
            $ falar no whatsapp →
          </a>
        </div>
      </div>
      <div class="hero-terminal">
        <Terminal lines={terminalLines} />
      </div>
    </div>
  </section>

  <section class="row contato-canais">
    <div class="container-page">
      <div class="row-header">
        <span class="num">01</span>
        <h2>Canais</h2>
      </div>
      <p class="sub">Como falar comigo</p>

      <div class="canal-grid">
        <div class="glow-card canal">
          <p class="eyebrow" style="color: var(--whatsapp)">●  WhatsApp</p>
          <a href={whatsappLink()} target="_blank" rel="noopener" class="canal-link">{site.contact.whatsappLabel}</a>
          <p class="canal-hint">Resposta em até 4h em dia útil. Canal preferido pra primeiro contato.</p>
        </div>
        <div class="glow-card canal" style="--glow: var(--cerebro-glow)">
          <p class="eyebrow" style="color: var(--cerebro)">●  E-mail</p>
          <a href={`mailto:${site.contact.email}`} class="canal-link">{site.contact.email}</a>
          <p class="canal-hint">Use pra proposta formal ou contrato.</p>
        </div>
        <div class="glow-card canal" style="--glow: var(--engrenagens-glow)">
          <p class="eyebrow" style="color: var(--engrenagens)">●  Instagram</p>
          <a href={site.social.instagram} target="_blank" rel="noopener" class="canal-link">@{site.contact.instagram}</a>
          <p class="canal-hint">Conteúdo + bastidores. DM responde em até 24h.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="row contato-atendimento">
    <div class="container-page">
      <div class="row-header">
        <span class="num">02</span>
        <h2>Atendimento</h2>
      </div>
      <p class="sub">Presencial · Remoto</p>
      <p class="lead">
        <strong>{site.contact.address}.</strong> Atendo presencial em <strong>{site.contact.region.join(', ')}</strong>. Para outras regiões, atendimento é remoto via Google Meet — sem perda de profundidade no diagnóstico nem na entrega.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 80px 0 50px;
  }
  .hero-mark {
    margin-bottom: 22px;
  }
  .hero-grid {
    display: grid;
    gap: 56px;
    align-items: center;
  }
  @media (min-width: 1000px) {
    .hero-grid {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .hero-title {
    margin-top: 18px;
    font-size: clamp(36px, 5vw, 60px);
    line-height: 1.05;
  }
  .hero-subtitle {
    margin-top: 22px;
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.7;
    max-width: 560px;
  }
  .hero-subtitle strong {
    color: var(--text);
    font-weight: 500;
  }
  .hero-ctas {
    margin-top: 32px;
  }

  .canal-grid {
    margin-top: 28px;
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .canal-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .canal {
    padding: 28px;
  }
  .canal-link {
    display: block;
    margin-top: 12px;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--text);
    line-height: 1.2;
  }
  .canal-link:hover {
    color: var(--claude);
  }
  .canal-hint {
    margin-top: 12px;
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>
