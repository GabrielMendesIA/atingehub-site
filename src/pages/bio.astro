---
import '../styles/global.css';
import { site, whatsappLink } from '../config/site';

const links = [
  {
    label: '$ conversar no WhatsApp',
    href: whatsappLink('Oi, vim pelo Instagram da AtingeHUB. Quero conversar.'),
    desc: 'resposta em até 4h em dia útil',
    external: true,
    primary: true,
    color: 'var(--whatsapp)',
  },
  {
    label: 'Conhecer o sistema',
    href: 'https://atingehub.com',
    desc: 'home do site · manifesto · 8 produtos',
    external: true,
    color: 'var(--text)',
  },
  {
    label: 'Ver os 8 produtos',
    href: 'https://atingehub.com/portfolio',
    desc: 'Vitrine · Cérebro · Bancada · Engrenagens · Cadência · Balcão · Voz · Bússola',
    external: true,
    color: 'var(--claude)',
  },
  {
    label: 'Sobre o Gabriel',
    href: 'https://atingehub.com/sobre',
    desc: '5 anos atendendo empresários do varejo · AUTOMAKER · Açaí Algomais',
    external: true,
    color: 'var(--cerebro)',
  },
  {
    label: 'AtingeHUB Stack · pra devs e parceiros',
    href: site.social.github,
    desc: 'plugin Claude Code com 48 skills + agente SEO',
    external: true,
    color: 'var(--cadencia)',
  },
  {
    label: `${site.contact.email}`,
    href: `mailto:${site.contact.email}`,
    desc: 'pra proposta formal ou contrato',
    external: false,
    color: 'var(--bussola)',
  },
];

const ogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${site.name} · Links`,
  url: `${site.url}/bio`,
  description: 'Links principais da AtingeHUB — WhatsApp, portfólio, sobre, contato.',
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#050505" />
    <title>{site.name} · Links</title>
    <meta name="description" content="Links principais da AtingeHUB — WhatsApp, portfólio, sobre, contato." />
    <meta name="robots" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${site.name} · Sistemas de IA para varejo brasileiro`} />
    <meta property="og:description" content="Cada produto resolve um problema concreto. Stack aberta. Relação humana em primeiro lugar." />
    <meta property="og:url" content={`${site.url}/bio`} />
    <meta property="og:image" content={`${site.url}/og/default.png`} />
    <meta property="og:locale" content="pt_BR" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700;9..144,800;9..144,900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(ogJsonLd)} />
  </head>
  <body class="bio-body">
    <main class="bio">
      <header class="bio-head">
        <svg
          class="bio-logo"
          viewBox="0 0 100 80"
          aria-hidden="true"
        >
          <path d="M16 64L28 42L40 64Z" fill="#4A4A4A" />
          <path d="M60 64L74 38L88 64Z" fill="#8A8A8A" />
          <path d="M24 64L50 16L76 64Z" fill="#F5F3EE" />
          <path d="M50 16L50 6" stroke="#D97757" stroke-width="2.5" stroke-linecap="round" />
          <path d="M50 7L60 9L50 13Z" fill="#D97757" />
        </svg>
        <h1 class="bio-name">
          Atinge<span class="hub">HUB</span>
        </h1>
        <p class="bio-tagline">
          Sistemas de <em>IA</em> para o varejo brasileiro.<br />
          <span class="bio-sub">Sorocaba/SP · {site.contact.region.slice(0, 4).join(' · ')}</span>
        </p>
      </header>

      <nav class="bio-links" aria-label="Links principais">
        {links.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener' : undefined}
            class:list={['bio-link', link.primary ? 'bio-link-primary' : '']}
            style={`--accent: ${link.color}`}
          >
            <div class="bio-link-body">
              <span class="bio-link-label">{link.label}</span>
              <span class="bio-link-desc">{link.desc}</span>
            </div>
            <span class="bio-link-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </nav>

      <footer class="bio-foot">
        <p class="bio-foot-eyebrow">●  AtingeHUB · 2026</p>
        <p class="bio-foot-line">
          <a href={site.social.instagram} target="_blank" rel="noopener">@{site.contact.instagram}</a>
          <span class="bio-foot-sep">·</span>
          <a href="https://atingehub.com/privacidade" target="_blank" rel="noopener">privacidade</a>
        </p>
      </footer>
    </main>

    <style>
      .bio-body {
        background: var(--bg);
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      .bio-body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
        background-size: 48px 48px;
        pointer-events: none;
        z-index: 0;
      }

      .bio-body::after {
        content: '';
        position: fixed;
        top: -20%;
        left: 50%;
        transform: translateX(-50%);
        width: 90vw;
        height: 60vh;
        background: radial-gradient(ellipse, var(--claude-glow), transparent 60%);
        opacity: 0.5;
        pointer-events: none;
        z-index: 0;
      }

      .bio {
        position: relative;
        z-index: 1;
        max-width: 480px;
        margin: 0 auto;
        padding: 56px 22px 48px;
        display: flex;
        flex-direction: column;
        gap: 36px;
      }
      @media (max-width: 480px) {
        .bio {
          padding: 40px 18px 32px;
          gap: 28px;
        }
      }

      .bio-head {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
      }

      .bio-logo {
        width: 96px;
        height: 76px;
        filter: drop-shadow(0 0 24px rgba(217, 119, 87, 0.55));
      }

      .bio-name {
        font-family: var(--font-display);
        font-weight: 800;
        letter-spacing: -0.04em;
        font-size: clamp(40px, 9vw, 52px);
        line-height: 1;
        color: var(--text);
        margin: 0;
      }
      .bio-name .hub {
        font-weight: 900;
        color: var(--claude);
      }

      .bio-tagline {
        font-family: var(--font-display);
        font-style: italic;
        font-weight: 400;
        font-size: 16px;
        line-height: 1.45;
        color: var(--text);
        max-width: 320px;
        margin: 0;
      }
      .bio-tagline em {
        font-style: italic;
        font-weight: 900;
        color: var(--claude);
      }
      .bio-sub {
        font-family: var(--font-mono);
        font-style: normal;
        font-size: 10.5px;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--text-dim);
        display: block;
        margin-top: 8px;
      }

      .bio-links {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .bio-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 18px 20px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        color: var(--text);
        text-decoration: none;
        transition: transform 0.18s ease, border-color 0.18s, background 0.18s, box-shadow 0.18s;
        position: relative;
        overflow: hidden;
      }
      .bio-link::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        width: 3px;
        background: var(--accent);
        opacity: 0.85;
      }
      .bio-link:hover,
      .bio-link:focus-visible {
        border-color: var(--border-strong);
        background: var(--bg-card-hover);
        transform: translateY(-1px);
        color: var(--text);
      }

      .bio-link-primary {
        background: var(--whatsapp);
        border-color: var(--whatsapp);
        color: var(--ink);
        box-shadow: 0 0 32px rgba(37, 211, 102, 0.35);
      }
      .bio-link-primary::before {
        display: none;
      }
      .bio-link-primary:hover,
      .bio-link-primary:focus-visible {
        background: var(--whatsapp);
        border-color: var(--whatsapp);
        color: var(--ink);
        filter: brightness(1.06);
      }
      .bio-link-primary .bio-link-desc {
        color: rgba(10, 10, 10, 0.7);
      }

      .bio-link-body {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
      }

      .bio-link-label {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 17px;
        line-height: 1.2;
        letter-spacing: -0.015em;
      }

      .bio-link-desc {
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: 0.4px;
        color: var(--text-muted);
        line-height: 1.45;
      }

      .bio-link-arrow {
        font-family: var(--font-mono);
        font-size: 18px;
        color: var(--accent);
        flex-shrink: 0;
        transition: transform 0.2s;
      }
      .bio-link:hover .bio-link-arrow {
        transform: translateX(3px);
      }
      .bio-link-primary .bio-link-arrow {
        color: var(--ink);
      }

      .bio-foot {
        margin-top: 8px;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .bio-foot-eyebrow {
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-dim);
      }
      .bio-foot-line {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-dim);
        letter-spacing: 0.5px;
      }
      .bio-foot-line a {
        color: var(--text-muted);
      }
      .bio-foot-line a:hover {
        color: var(--text);
      }
      .bio-foot-sep {
        margin: 0 8px;
      }
    </style>
  </body>
</html>
