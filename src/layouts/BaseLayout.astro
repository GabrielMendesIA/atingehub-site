---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: object | object[];
  productContext?: string;
}

const props = Astro.props;
const { productContext, ...seoProps } = props;
---

<!doctype html>
<html lang="pt-BR" data-product={productContext}>
  <head>
    <SEO {...seoProps} />
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
