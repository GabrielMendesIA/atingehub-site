# ─── AtingeHUB · Variáveis de ambiente ──────────────────────────
# Copie esse arquivo pra .env.local pra rodar localmente.
# No Vercel, configure cada variável em Project Settings → Environment Variables.

# ─── n8n (backend dos formulários) ───────────────────────────────
# Backend dos forms vive no n8n da sua VPS Hostinger.
# Os 3 workflows criados via MCP:
#   POST /webhook/atingehub-lead       (form da home)
#   POST /webhook/atingehub-checkout   (cria preferência MP)
#   POST /webhook/atingehub-mp-webhook (recebe confirmação MP)
N8N_BASE_URL=https://workflows-mvp.algomaisacai.com.br/webhook

# ─── Variáveis usadas pelos workflows n8n ───────────────────────
# Estas NÃO ficam no Vercel — ficam no n8n (Settings → Variables).
# Estão aqui só pra documentar o que precisa configurar lá.

# Mercado Pago
# Painel: https://www.mercadopago.com.br/developers/panel/credentials
# MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# Evolution API (WhatsApp via VPS Hostinger)
# EVOLUTION_BASE_URL=https://evolution.seudominio.com
# EVOLUTION_INSTANCE=atingehub
# EVOLUTION_API_KEY=sua-api-key-da-evolution
# OWNER_WHATSAPP=5515998554455
# WORKSHOP_GROUP_JID=120363xxxxxxxxxxxx@g.us

# GitHub
# Personal Access Token classic com escopo 'repo'
# https://github.com/settings/tokens/new
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=GabrielMendesIA/atingehub-stack

# Google Sheets (via credencial OAuth no n8n)
# Configure no próprio n8n: criar credencial Google Sheets OAuth.
# IDs das planilhas (peguinhe na URL: /spreadsheets/d/<ESSE-ID>/edit)
# SHEETS_LEADS_ID=1AbCDeFgH...
# SHEETS_SALES_ID=1XyZW...
