# ─── AtingeHUB · Variáveis de ambiente ──────────────────────────
# Copie esse arquivo pra .env.local pra rodar localmente.
# No Vercel, coloque cada variável em Project Settings → Environment Variables.

# ─── Mercado Pago ────────────────────────────────────────────────
# Painel: https://www.mercadopago.com.br/developers/panel/credentials
# Use APP_USR-... (production) ou TEST-... (sandbox)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ─── ntfy push ───────────────────────────────────────────────────
# Crie o tópico abrindo a URL https://ntfy.sh/<topico> uma vez.
# Sem senha, sem cadastro — público. Use nome difícil de adivinhar.
NTFY_TOPIC=atingehub-leads-Sr0c4ba

# ─── Evolution API (WhatsApp via VPS Hostinger) ──────────────────
# Painel da sua VPS, instância que conecta ao seu Zap.
EVOLUTION_BASE_URL=https://evolution.seudominio.com
EVOLUTION_INSTANCE=atingehub
EVOLUTION_API_KEY=sua-api-key-da-evolution

# Telefone que recebe notificação de lead (E.164 sem +)
OWNER_WHATSAPP=5515998554455

# JID do grupo de alunos do Workshop (formato xxxxx@g.us)
# Pra descobrir: na Evolution, GET /group/findAllGroups/{instance}
WORKSHOP_GROUP_JID=120363xxxxxxxxxxxx@g.us

# ─── GitHub (acesso ao repo Stack) ───────────────────────────────
# Personal Access Token classic com escopo 'repo' (full control)
# Crie em: https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=GabrielMendesIA/atingehub-stack

# ─── Google Sheets ───────────────────────────────────────────────
# Crie um Service Account em https://console.cloud.google.com/iam-admin/serviceaccounts
# Habilite a Google Sheets API no projeto.
# Compartilhe as planilhas (Leads e Vendas) com o email da Service Account
# como Editor.
GOOGLE_SA_EMAIL=atingehub-bot@meu-projeto.iam.gserviceaccount.com
# Cole a chave privada completa entre aspas, com \n literal pras quebras
GOOGLE_SA_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIB...\n-----END PRIVATE KEY-----\n"

# IDs das planilhas (peguinhe na URL: /spreadsheets/d/<ESSE-ID>/edit)
SHEETS_LEADS_ID=1AbCDeFgH...
SHEETS_SALES_ID=1XyZW...
