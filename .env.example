# AtingeHUB site · variáveis de ambiente
#
# Copie esse arquivo pra .env.local em desenvolvimento.
# Em produção, configure essas variáveis no painel da Vercel:
# https://vercel.com/mendesofc1-3588s-projects/atingehub-site/settings/environment-variables

# Chave da API Claude (Anthropic) — usada em /api/diagnose pra gerar o prognóstico.
# Pegar em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# URL do webhook n8n que recebe cada lead + brief comercial.
# Roda na VPS do Gabriel (ex.: https://n8n.atingehub.com.br/webhook/diagnostico).
N8N_WEBHOOK_URL=https://n8n.exemplo.com/webhook/diagnostico
